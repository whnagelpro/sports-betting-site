function fetchAllNHLTeams_() {
  const response = fetchApi_('/nhl/v1/teams', {
    per_page: 100
  });

  return Array.isArray(response.data) ? response.data : [];
}

function fetchAllNHLBoxScoresForGameIds_(gameIds) {
  const allRows = [];

  gameIds.forEach((gameId, index) => {
    Logger.log(`Fetching NHL box scores for game ${index + 1}/${gameIds.length} (ID: ${gameId})`);

    let cursor = null;

    do {
      const params = {
        "game_ids[]": gameId,
        per_page: 100
      };

      if (cursor) {
        params.cursor = cursor;
      }

      const response = fetchApi_('/nhl/v1/box_scores', params);
      const rows = Array.isArray(response.data) ? response.data : [];
      allRows.push(...rows);

      cursor = response.meta && response.meta.next_cursor
        ? response.meta.next_cursor
        : null;

    } while (cursor);

    Utilities.sleep(150);
  });

  return allRows;
}

function normalizeNHLTeamName_(name) {
  return String(name || "")
    .toLowerCase()
    .replace(/\./g, "")
    .replace(/\s+/g, " ")
    .trim();
}

