function fetchRecentNHLStats_(daysBack = 14) {
  const allStats = [];
  let cursor = null;

  const tz = SpreadsheetApp.getActiveSpreadsheet().getSpreadsheetTimeZone() || Session.getScriptTimeZone();
  const today = new Date();
  const startDate = new Date(today.getTime() - daysBack * 24 * 60 * 60 * 1000);

  const startStr = Utilities.formatDate(startDate, tz, "yyyy-MM-dd");
  const endStr = Utilities.formatDate(today, tz, "yyyy-MM-dd");

  do {
    const params = {
      start_date: startStr,
      end_date: endStr,
      per_page: 100
    };

    if (cursor) {
      params.cursor = cursor;
    }

    const response = fetchApi_('/nhl/v1/stats', params);
    const stats = Array.isArray(response.data) ? response.data : [];
    allStats.push(...stats);

    cursor = response.meta && response.meta.next_cursor
      ? response.meta.next_cursor
      : null;

  } while (cursor);

  return allStats;
}

function toNumber_(value) {
  if (value === null || value === undefined || value === "") return 0;
  const num = Number(value);
  return isNaN(num) ? 0 : num;
}

function buildNHLBaselineRows_(stats, gamesToUse = 5) {
  const playerGameMap = {};

  stats.forEach(stat => {
    const player =
      stat.player ||
      {};

    const team =
      stat.team ||
      player.team ||
      {};

    const game =
      stat.game ||
      {};

    const playerId =
      stat.player_id ||
      player.id ||
      "";

    if (!playerId) return;

    const gameId =
      stat.game_id ||
      game.id ||
      "";

    const gameDate =
      game.date ||
      game.game_date ||
      stat.date ||
      "";

    const playerName =
      player.full_name ||
      [player.first_name || "", player.last_name || ""].join(" ").trim();

    const teamName =
      team.full_name ||
      team.name ||
      team.display_name ||
      team.abbreviation ||
      "";

    if (!playerGameMap[playerId]) {
      playerGameMap[playerId] = [];
    }

    playerGameMap[playerId].push({
      playerId: String(playerId),
      playerName: playerName,
      teamName: teamName,
      gameId: String(gameId),
      gameDate: gameDate,
      shots_on_goal: toNumber_(stat.shots_on_goal),
      points: toNumber_(stat.points),
      assists: toNumber_(stat.assists),
      goals: toNumber_(stat.goals),
      blocked_shots: toNumber_(stat.blocked_shots),
      hits: toNumber_(stat.hits)
    });
  });

  const rows = [];

  Object.keys(playerGameMap).forEach(playerId => {
    const games = playerGameMap[playerId]
      .sort((a, b) => {
        const aTime = a.gameDate ? new Date(a.gameDate).getTime() : 0;
        const bTime = b.gameDate ? new Date(b.gameDate).getTime() : 0;
        return bTime - aTime;
      })
      .slice(0, gamesToUse);

    if (!games.length) return;

    const first = games[0];
    const used = games.length;

    const avg = key =>
      games.reduce((sum, g) => sum + toNumber_(g[key]), 0) / used;

    rows.push([
      first.playerId,                 // A Player Id
      first.playerName,               // B Player Name
      first.teamName,                 // C Team
      avg("shots_on_goal"),           // D shots_on_goal
      avg("points"),                  // E points
      avg("assists"),                 // F assists
      avg("goals"),                   // G goals
      avg("blocked_shots"),           // H blocked_shots
      avg("hits"),                    // I hits
      used                            // J games_used
    ]);
  });

  rows.sort((a, b) => {
    const nameA = (a[1] || "").toLowerCase();
    const nameB = (b[1] || "").toLowerCase();
    return nameA.localeCompare(nameB);
  });

  return rows;
}

