  playerIds.forEach((playerId, index) => {
    Logger.log(`Fetching NHL season stats for player ${index + 1}/${playerIds.length} (ID: ${playerId})`);

    const statsArray = fetchNHLPlayerSeasonStats_(playerId, season);
    const statMap = seasonStatsArrayToMap_(statsArray);

    const gamesPlayed = Number(statMap.games_played || 0);
    if (!gamesPlayed) {
      Utilities.sleep(100);
      return;
    }

    const playerInfo = playerLookup[String(playerId)] || {};

    const goalsPerGame = getStatFlexible_(statMap, ["goals"], gamesPlayed);
    const assistsPerGame = getStatFlexible_(statMap, ["assists"], gamesPlayed);
    const pointsPerGame = getStatFlexible_(statMap, ["points"], gamesPlayed);
    const powerPlayPointsPerGame = getStatFlexible_(statMap, ["power_play_points"], gamesPlayed);
    const savesPerGame = getStatFlexible_(statMap, ["saves"], gamesPlayed);
    const shotsPerGame = getStatFlexible_(statMap, ["shots", "shots_on_goal"], gamesPlayed);

    const goal1P = goalsPerGame * P1_FACTOR;
    const goal2P = goalsPerGame * P2_FACTOR;
    const goal3P = goalsPerGame * P3_FACTOR;

    const points1P = pointsPerGame * P1_FACTOR;
    const points2P = pointsPerGame * P2_FACTOR;
    const points3P = pointsPerGame * P3_FACTOR;

    const shots1P = shotsPerGame * P1_FACTOR;
    const shots2P = shotsPerGame * P2_FACTOR;
    const shots3P = shotsPerGame * P3_FACTOR;

    rows.push([
      playerId,                    // A Player Id
      playerInfo.playerName || "", // B Player Name

      goalsPerGame,                // C anytime_goal
      goal1P,                      // D anytime_goal_1p
      goal2P,                      // E anytime_goal_2p
      goal3P,                      // F anytime_goal_3p

      assistsPerGame,              // G assists

      goalsPerGame,                // H first_goal
      goal1P,                      // I first_goal_1p
      goal2P,                      // J first_goal_2p
      goal3P,                      // K first_goal_3p

      goalsPerGame,                // L goals

      goalsPerGame,                // M last_goal
      goalsPerGame * 0.10,         // N overtime_goal (rough proxy)

      pointsPerGame,               // O points
      points1P,                    // P points_1p
      points2P,                    // Q points_2p
      points3P,                    // R points_3p

      powerPlayPointsPerGame,      // S power_play_points
      savesPerGame,                // T saves

      goalsPerGame,                // U second_goal

      shotsPerGame,                // V shots_on_goal
      shots1P,                     // W shots_on_goal_1p
      shots2P,                     // X shots_on_goal_2p
      shots3P,                     // Y shots_on_goal_3p

      goalsPerGame,                // Z third_goal

      gamesPlayed                  // AA games_used
    ]);

    Utilities.sleep(100);
  });

  rows.sort((a, b) => {
    const nameA = (a[1] || "").toLowerCase();
    const nameB = (b[1] || "").toLowerCase();
    return nameA.localeCompare(nameB);
  });

  clearNHLBaselinesSheet_(sheet);

  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);

  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }

  Logger.log(`Wrote ${rows.length} NHL baseline rows to "${sheetName}" for season ${season}`);
}

function getCurrentNHLSeason_() {
  const tz = SpreadsheetApp.getActiveSpreadsheet().getSpreadsheetTimeZone() || Session.getScriptTimeZone();
  const now = new Date();
  const month = Number(Utilities.formatDate(now, tz, "M"));
  const year = Number(Utilities.formatDate(now, tz, "yyyy"));

  return month >= 9 ? year : year - 1;
}

function getBoxScoreStatFlexible_(obj, keys) {
  for (let i = 0; i < keys.length; i++) {
    const key = keys[i];
    if (obj[key] !== undefined && obj[key] !== null && obj[key] !== "") {
      const value = Number(obj[key]);
      if (!isNaN(value)) return value;
    }
  }
  return 0;
}

