  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error(`Sheet "${sheetName}" not found.`);
  }

  Logger.log("Refreshing NHL Trends from recent box scores...");

  const headers = [
    "Player Id",
    "Player Name",
    "shots_on_goal_last5",
    "points_last5",
    "assists_last5",
    "goals_last5",
    "power_play_points_last5",
    "saves_last5",
    "games_used_last5"
  ];

  const season = getCurrentNHLSeason_();
  const playerIds = getNHLPlayerIdsFromPlayerProps_();
  const playerLookup = getNHLPlayerLookupMap_();

  const rows = [];

  playerIds.forEach((playerId, index) => {
    Logger.log(`Fetching NHL box scores for player ${index + 1}/${playerIds.length} (ID: ${playerId})`);

    const boxScores = fetchRecentNHLBoxScoresForPlayer_(playerId, season);

    const sorted = boxScores
      .slice()
      .sort((a, b) => {
        const aDate = new Date(
          (a.game && (a.game.date || a.game.game_date)) || a.date || 0
        ).getTime();
        const bDate = new Date(
          (b.game && (b.game.date || b.game.game_date)) || b.date || 0
        ).getTime();
        return bDate - aDate;
      })
      .slice(0, 5);

    const used = sorted.length;
    if (!used) {
      Utilities.sleep(100);
      return;
    }

    const avg = (keys) =>
      sorted.reduce((sum, row) => sum + getBoxScoreStatFlexible_(row, keys), 0) / used;

    const playerInfo = playerLookup[String(playerId)] || {};

    rows.push([
      playerId,
      playerInfo.playerName || "",
      avg(["shots", "shots_on_goal"]),
      avg(["points"]),
      avg(["assists"]),
      avg(["goals"]),
      avg(["power_play_points"]),
      avg(["saves"]),
      used
    ]);

    Utilities.sleep(100);
  });

  rows.sort((a, b) => {
    const nameA = (a[1] || "").toLowerCase();
    const nameB = (b[1] || "").toLowerCase();
    return nameA.localeCompare(nameB);
  });

  clearNHLTrendsSheet_(sheet);

  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);

  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }

  Logger.log(`Wrote ${rows.length} NHL trend rows to "${sheetName}"`);
}

