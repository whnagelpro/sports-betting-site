      allRows.push([
        game.id,                  // A Game Id
        gameInfo.game_date,       // B Game Date
        gameInfo.away_team,       // C Away Team
        gameInfo.home_team,       // D Home Team
        prop.id || "",            // E Id
        playerId,                 // F Player Id
        vendor,                   // G Vendor
        propType,                 // H Prop Type
        lineValue,                // I Line Value
        typeValue,                // J Type
        odds,                     // K Odds
        updatedAt,                // L Updated At
        overOdds,                 // M Over Odds
        underOdds                 // N Under Odds
      ]);
    });

    Utilities.sleep(200);
  });

  clearPlayerPropsData_(sheet);

  if (!allRows.length) {
    Logger.log("No NHL player props were returned for the schedule slate.");
    return;
  }

  sheet.getRange(3, 1, allRows.length, 14).setValues(allRows);

  copyFormulaTemplatesDown_(sheet, allRows.length);

  Logger.log(`Wrote ${allRows.length} NHL player props rows to "${sheetName}"`);
}

