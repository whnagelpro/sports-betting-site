// ============================================================================
// GENERIC API FUNCTION
// ============================================================================

/**
 * Call any BALLDONTLIE API endpoint directly
 * @param {string} endpoint The API endpoint (e.g., "/nba/v1/teams")
 * @param {string} paramsJson Optional JSON string of query parameters
 * @returns {Array} API response data
 * @customfunction
 */
function BDL_API(endpoint, paramsJson) {
  if (!endpoint) throw new Error('Endpoint is required');
  let params = {};
  if (paramsJson) {
    try {
      params = JSON.parse(paramsJson);
    } catch (e) {
      throw new Error('Invalid JSON parameters: ' + e.message);
    }
  }
  const response = fetchApi_(endpoint, params);
  return toSheet_(response.data);
}