/**
 * Fetches all NHL games for a specific date, handling pagination.
 * @param {string} dateString YYYY-MM-DD
 * @returns {Array<Object>}
 */
function fetchAllNHLGamesForDate_(dateString) {
  const allGames = [];
  let cursor = null;

  do {
    const params = {
      "dates[]": dateString,
      per_page: 100
    };

    if (cursor) {
      params.cursor = cursor;
    }

    const response = fetchApi_('/nhl/v1/games', params);
    const games = Array.isArray(response.data) ? response.data : [];
    allGames.push(...games);

    cursor = response.meta && response.meta.next_cursor
      ? response.meta.next_cursor
      : null;
  } while (cursor);

  return allGames;
}

function isCompletedNHLGame_(game) {
  const status = String(
    game.status ||
    game.game_state ||
    game.state ||
    game.detailed_state ||
    ""
  ).toLowerCase().trim();

  Logger.log(`NHL STATUS CHECK -> ${status}`);

  return (
    status.includes("final") ||
    status.includes("completed") ||
    status.includes("finished") ||
    status.includes("game over") ||
    status === "final" ||
    status === "off"
  );
}

