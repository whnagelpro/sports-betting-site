function getStatFlexible_(statMap, keys, gamesPlayed) {
  if (!gamesPlayed || gamesPlayed <= 0) return 0;

  for (let i = 0; i < keys.length; i++) {
    const key = keys[i];
    if (statMap[key] !== undefined && statMap[key] !== null && statMap[key] !== "") {
      const value = Number(statMap[key]);
      if (!isNaN(value)) {
        return value / gamesPlayed;
      }
    }
  }

  return 0;
}

