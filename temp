function fetchAllNHLActivePlayersFromTeamRosters_() {
  const teamsResponse = fetchApi_('/nhl/v1/teams', { per_page: 100 });
  const teams = Array.isArray(teamsResponse.data) ? teamsResponse.data : [];

  const playerMap = {};

  teams.forEach((team, index) => {
    Logger.log(`Fetching NHL roster ${index + 1}/${teams.length} for team ID ${team.id}`);

    const rosterPlayers = fetchNHLRosterForTeam_(team.id);

    rosterPlayers.forEach(player => {
      if (!player.id) return;

      // Attach team info if missing from roster player object
      if (!player.team) {
        player.team = {
          id: team.id || "",
          full_name: team.full_name || "",
          abbreviation: team.abbreviation || "",
          conference: team.conference || "",
          division: team.division || ""
        };
      }

      playerMap[player.id] = player;
    });

    Utilities.sleep(200);
  });

  return Object.values(playerMap).sort((a, b) => {
    const aName = `${a.last_name || ""} ${a.first_name || ""}`.trim();
    const bName = `${b.last_name || ""} ${b.first_name || ""}`.trim();
    return aName.localeCompare(bName);
  });
}

