/**
 * BALLDONTLIE API - Google Sheets Integration
 *
 * This script provides custom functions to fetch sports data from the BALLDONTLIE API
 * directly in Google Sheets.
 *
 * SETUP:
 * 1. Open your Google Sheet
 * 2. Go to Extensions > Apps Script
 * 3. Copy this entire script into the editor
 * 4. Run the BDL_SET_API_KEY function once to set your API key
 * 5. Use the custom functions in your spreadsheet cells
 *
 * Get your API key at: https://app.balldontlie.io
 * Documentation: https://www.balldontlie.io/docs
 */

// ============================================================================
// CONFIGURATION
// ============================================================================

const BASE_URL = 'https://api.balldontlie.io';

/**
 * Sets your BALLDONTLIE API key. Run this once from the Apps Script editor.
 * @param {string} apiKey Your API key from app.balldontlie.io
 * @customfunction
 */
function BDL_SET_API_KEY(apiKey) {
  if (!apiKey || apiKey.trim() === '') {
    throw new Error('API key cannot be empty. Get your key at app.balldontlie.io');
  }
  PropertiesService.getUserProperties().setProperty('BDL_API_KEY', apiKey.trim());
  return 'API key saved successfully!';
}

/**
 * Gets the stored API key
 * @returns {string} The API key
 */
function getApiKey_() {
  const key = PropertiesService.getUserProperties().getProperty('BDL_API_KEY');
  if (!key) {
    throw new Error('API key not set. Run BDL_SET_API_KEY("your-api-key") first.');
  }
  return key;
}

