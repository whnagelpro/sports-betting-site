function getRecentCompletedNHLGamesForTeamTrends_(gamesNeededPerTeam, maxLookbackDays) {
  const teams = fetchAllNHLTeams_();
  const teamNeedMap = {};
  const selectedGameMap = {};

  teams.forEach(team => {
    teamNeedMap[String(team.id)] = [];
  });

  for (let daysAgo = 1; daysAgo <= maxLookbackDays; daysAgo++) {
    const dateString = getPastDateString_(daysAgo);
    Logger.log(`Checking NHL completed games for ${dateString}...`);

    const rawGames = fetchAllNHLGamesForDate_(dateString);
Logger.log(`NHL raw games for ${dateString}: ${rawGames.length}`);

const games = rawGames.filter(isCompletedNHLGame_);
Logger.log(`NHL completed games for ${dateString}: ${games.length}`);

    games.sort((a, b) => {
      const aDate = new Date(a.date || a.game_date || 0).getTime();
      const bDate = new Date(b.date || b.game_date || 0).getTime();
      return bDate - aDate;
    });

    games.forEach(game => {
      const gameId = String(game.id || "");
      const homeTeamId = String((game.home_team && game.home_team.id) || "");
      const awayTeamId = String((game.away_team && game.away_team.id) || "");

      if (!gameId || !homeTeamId || !awayTeamId) return;

      if (teamNeedMap[homeTeamId] && teamNeedMap[homeTeamId].length < gamesNeededPerTeam) {
        if (!teamNeedMap[homeTeamId].some(g => String(g.id) === gameId)) {
          teamNeedMap[homeTeamId].push(game);
          selectedGameMap[gameId] = game;
        }
      }

      if (teamNeedMap[awayTeamId] && teamNeedMap[awayTeamId].length < gamesNeededPerTeam) {
        if (!teamNeedMap[awayTeamId].some(g => String(g.id) === gameId)) {
          teamNeedMap[awayTeamId].push(game);
          selectedGameMap[gameId] = game;
        }
      }
    });

    Utilities.sleep(150);

    const allSatisfied = Object.values(teamNeedMap).every(arr => arr.length >= gamesNeededPerTeam);
    if (allSatisfied) break;
  }

  return {
    teams,
    teamGamesMap: teamNeedMap,
    selectedGames: Object.values(selectedGameMap)
  };
}

function buildNHLTeamGameStatsMap_(boxScoreRows) {
  const map = {};

  boxScoreRows.forEach(row => {
    const gameId = String(
      row.game_id ||
      (row.game && row.game.id) ||
      ""
    ).trim();

    const rawTeamName =
      row.team_name ||
      (row.team && (row.team.full_name || row.team.name)) ||
      "";

    const teamName = normalizeNHLTeamName_(rawTeamName);

    if (!gameId || !teamName) return;

    const key = `${gameId}_${teamName}`;

    if (!map[key]) {
      map[key] = {
        goals: 0,
        shots_on_goal: 0,
        assists: 0,
        points: 0,
        rowCount: 0
      };
    }

    map[key].goals += Number(row.goals || 0);
    map[key].shots_on_goal += Number(row.shots_on_goal || row.sog || 0);
    map[key].assists += Number(row.assists || row.ast || 0);
    map[key].points += Number(row.points || 0);
    map[key].rowCount += 1;
  });

  const sampleKeys = Object.keys(map).slice(0, 5);
  sampleKeys.forEach(k => {
    Logger.log(`NHL MAP SAMPLE: ${k} -> ${JSON.stringify(map[k])}`);
  });

  return map;
}

